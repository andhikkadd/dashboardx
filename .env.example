# Database Connection
# Replace with your local or production PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dashboard_x?schema=public"

# Auth configurations
# Generate a secure secret key, e.g. using `openssl rand -base64 32`
NEXTAUTH_SECRET="super-secret-key-change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Enkripsi untuk storage state Playwright (harus 32 bytes/64 karakter hex)
# Contoh generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Playwright Scraper settings
PLAYWRIGHT_HEADLESS="true"
STORAGE_STATES_DIR="./storage-states"

# Sync parameters
SYNC_INTERVAL_MINUTES="30"
MAX_ACCOUNTS_PER_USER="10"
